axes[1].set_xlabel('Mode de paiement')
axes[1].set_ylabel('Panier moyen (BRL)')
for i, val in enumerate(pay_agg['panier_moyen']):
    axes[1].text(i, val + 2, f'{val:.0f} R$', ha='center', fontsize=9, fontweight='bold')

